@page
@model BarberBooking.Areas.Identity.Pages.Account.ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Reset hasla";
}

<section class="auth-panel">
    <div class="auth-copy">
        <p class="eyebrow">Reset dostepu</p>
        <h1>Sprawdz skrzynke</h1>
        <p>Jesli konto istnieje, instrukcja resetu hasla zostalaby wyslana na podany adres e-mail.</p>
    </div>

    <div class="form-card auth-card">
        <div class="auth-note auth-note-block">
            <strong>Informacja demo</strong>
            <span>Wysylka e-mail nie jest skonfigurowana, wiec to tylko makieta przeplywu resetowania hasla.</span>
        </div>
        <a class="btn btn-gold w-100 mt-3" asp-page="./Login">Wroc do logowania</a>
    </div>
</section>
