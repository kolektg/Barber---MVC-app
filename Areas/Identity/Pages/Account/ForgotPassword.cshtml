@page
@model BarberBooking.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Reset hasla";
}

<section class="auth-panel">
    <div class="auth-copy">
        <p class="eyebrow">Reset dostepu</p>
        <h1>Nie pamietasz hasla?</h1>
        <p>Podaj e-mail konta, a aplikacja przeprowadzi Cie przez reset hasla.</p>
        <div class="auth-note">
            <strong>Tryb demo</strong>
            <span>W projekcie nie ma skonfigurowanej wysylki e-mail, wiec to ekran pokazowy.</span>
        </div>
    </div>

    <form method="post" class="form-card auth-card">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label"></label>
            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="np. user@barberbooking.local" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-gold w-100">Przejdz dalej</button>

        <div class="auth-links">
            <a asp-page="./Login">Wroc do logowania</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
